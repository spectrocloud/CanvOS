#!/bin/sh
# Strip trailing np<N> suffix from predictable interface names assigned by udev.
# Modern drivers expose phys_port_name; older systemd (e.g. 249 on Ubuntu 22.04)
# always appends it. Names without np* (VMware ens*, AWS ens*, etc.) pass through unchanged.
set -eu

name=${1:-}
if [ -z "$name" ]; then
	exit 1
fi

short=$(printf '%s' "$name" | sed -E 's/np[0-9]+$//')
# Linux IFNAMSIZ is 16 bytes including the terminating NUL.
printf '%s\n' "$short" | cut -c1-15
